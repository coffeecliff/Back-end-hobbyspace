PORT=3000
JWT_SECRET=hobbyspace_super_secret_2024

# Token HuggingFace — crie em https://huggingface.co/settings/tokens
# Sem este token o chat IA retorna erro 503
HF_TOKEN=SEU_TOKEN_HUGGINGFACE_AQUI

# Firebase Admin SDK — preencha na Render para usar Firestore + Storage
# Se deixar vazio, o backend usa /data/db.json e /data/images localmente.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIRESTORE_COLLECTION=hobbyspace
FIRESTORE_DOC_ID=app-data
