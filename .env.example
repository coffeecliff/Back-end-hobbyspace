# ============================================================
# HobbySpace Backend — variáveis de ambiente
# Copie para .env e preencha com seus valores
# ============================================================

# Servidor
PORT=3000

# JWT (troque por uma string longa e aleatória)
JWT_SECRET=seu_jwt_secret_aqui_minimo_32_chars

# ── Supabase Storage (recomendado) ──────────────────────────
# Crie os buckets: avatars | posts | communities (Public)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=seu_service_role_key

# ── IA (chat) ───────────────────────────────────────────────
HF_TOKEN=seu_huggingface_token
